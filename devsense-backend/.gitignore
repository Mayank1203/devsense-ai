# ── Java / Maven ─────────────────────────────────────────────────────────────
# Compiled output — never commit, always regenerated by Maven
target/
*.class

# ── Secrets — NEVER commit these ────────────────────────────────────────────
.env
*.env

# ── IntelliJ IDEA ────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws

# ── VS Code ──────────────────────────────────────────────────────────────────
.vscode/

# ── Operating system files ───────────────────────────────────────────────────
.DS_Store          # Mac
Thumbs.db          # Windows

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/

# ── Built JARs (Railway builds from source, not pre-built JARs) ──────────────
*.jar
*.war
